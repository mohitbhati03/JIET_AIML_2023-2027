      "source": [
        "import cv2\n",
        "import numpy as np\n",
        "\n",
        "# Load image (grayscale)\n",
        "img = cv2.imread('Dhurandhar.jpeg', cv2.IMREAD_GRAYSCALE)\n",
        "\n",
        "# Compute mean and std deviation\n",
        "mean = np.mean(img)\n",
        "std_dev = np.std(img)\n",
        "\n",
        "print(\"Mean:\", mean)\n",
        "print(\"Standard Deviation:\", std_dev)"
      ]
    }
